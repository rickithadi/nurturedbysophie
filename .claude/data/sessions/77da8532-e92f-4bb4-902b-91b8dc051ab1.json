ice 2: Pilates -->\n                <div class=\"group p-8 md:p-10 rounded-2xl bg-[#fffdf7] border border-[#45572d]/10 hover:border-[#45572d]/40 transition-all duration-300 hover:shadow-xl hover:shadow-[#45572d]/5\">\n                    <div class=\"w-12 h-12 bg-[#45572d]/10 rounded-full flex items-center justify-center mb-8 text-[#45572d]\">\n                        <i data-lucide=\"activity\" class=\"w-6 h-6 stroke-[1.5]\"></i>\n                    </div>\n                    <h3 class=\"font-['Playfair_Display'] text-[#45572d] text-2xl md:text-3xl tracking-tight mb-4\">Mat Pilates</h3>\n                    <p class=\"text-lg leading-relaxed mb-8 font-light\">\n                        Gentle, strength-building movement designed specifically for the maternal body. Focus on pelvic floor health, core stability, and mindful breathing techniques.\n                    </p>\n                    <a href=\"#\" class=\"inline-flex items-center text-[#45572d] font-['Bodoni_Moda'] border-b border-[#45572d]/30 pb-1 hover:border-[#45572d] transition-colors\">\n                        View schedule <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2\"></i>\n                    </a>\n                </div>\n\n                <!-- Service 3: Breastfeeding -->\n                <div class=\"group p-8 md:p-10 rounded-2xl bg-[#fffdf7] border border-dashed border-[#45572d]/20 relative overflow-hidden\">\n                    <div class=\"absolute top-4 right-4 bg-[#717e5c]/10 px-3 py-1 rounded-full\">\n                        <span class=\"text-xs uppercase font-['Bodoni_Moda'] tracking-widest text-[#45572d]\">Coming Soon</span>\n                    </div>\n                    <div class=\"w-12 h-12 bg-[#45572d]/5 rounded-full flex items-center justify-center mb-8 text-[#45572d]/60\">\n                        <i data-lucide=\"heart-handshake\" class=\"w-6 h-6 stroke-[1.5]\"></i>\n                    </div>\n                    <h3 class=\"font-['Playfair_Display'] text-[#45572d]/70 text-2xl md:text-3xl tracking-tight mb-4\">Breastfeeding Support</h3>\n                    <p class=\"text-lg leading-relaxed mb-8 font-light text-[#717e5c]/80\">\n                        Specialized lactation consulting to support you and your baby in establishing a comfortable and successful breastfeeding relationship.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- About / Philosophy Section -->\n    <section id=\"about\" class=\"py-24 px-6 max-w-7xl mx-auto\">\n        <div class=\"flex flex-col md:flex-row items-center gap-16 md:gap-24\">\n            <div class=\"w-full md:w-1/2 relative\">\n                <div class=\"aspect-[4/5] rounded-tl-[100px] rounded-br-[100px] overflow-hidden bg-[#717e5c]/10\">\n                    <!-- Placeholder for Sophie's image -->\n                    <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/917d6f93-fb36-439a-8c48-884b67b35381_1600w.jpg\" alt=\"Midwife holding baby hands\" class=\"w-full h-full object-cover opacity-90 hover:scale-105 transition-transform duration-700\">\n                </div>\n                <!-- Decorative element -->\n                <div class=\"absolute -bottom-8 -left-8 text-[#45572d] rotate-12\">\n                    <i data-lucide=\"flower-2\" class=\"w-24 h-24 stroke-[0.5] opacity-20\"></i>\n                </div>\n            </div>\n            \n            <div class=\"w-full md:w-1/2\">\n                <span class=\"font-['Bodoni_Moda'] text-[#45572d] uppercase tracking-widest text-sm mb-6 block\">About Sophie</span>\n                <h2 class=\"font-['Playfair_Display'] text-[#45572d] text-4xl md:text-5xl tracking-tight font-medium mb-8\">My Philosophy</h2>\n                <div class=\"space-y-6 text-lg font-light leading-relaxed\">\n                    <p>\n                        I believe that birth is a profound rite of passage, not just a medical event. My approach is rooted in the understanding that when a woman feels safe, heard, and nurtured, her body can do the incredible work it was designed to do.\n                    </p>\n                    <p>\n                        Through a blend of evidence-based midwifery care and holistic movement practices like Pilates, I aim to bridge the gap between physical preparation and emotional well-being.\n                    </p>\n                    <p>\n                        \"Nurtured\" isn't just a name; it is the core tenet of my practice. Whether on the mat or in the birth suite, my role is to walk beside you.\n                    </p>\n                </div>\n                <div class=\"mt-10\">\n                    <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/4734259a-bad7-422f-981e-ce01e79184f2_1600w.jpg\" alt=\"Sophie Signature\" class=\"h-12 opacity-40 invert-[.35] sepia saturate-[.5] hue-rotate-[50deg]\"> \n                    <!-- Styled to look like green signature using CSS filters for demo purposes -->\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Journal / Resources Section -->\n    <section id=\"journal\" class=\"py-24 px-6 bg-[#45572d] text-[#fffdf7]\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"flex flex-col md:flex-row justify-between items-end mb-16 gap-8\">\n                <div>\n                    <span class=\"font-['Bodoni_Moda'] text-[#fffdf7]/60 uppercase tracking-widest text-sm mb-4 block\">Education</span>\n                    <h2 class=\"font-['Playfair_Display'] text-[#fffdf7] text-4xl md:text-5xl tracking-tight font-medium\">Research &amp; Resources</h2>\n                </div>\n                \n                <a href=\"#\" class=\"group flex items-center gap-3 bg-[#fffdf7] text-[#45572d] px-6 py-3 rounded-full font-['Bodoni_Moda'] text-sm hover:bg-[#717e5c] hover:text-[#fffdf7] transition-all duration-300\">\n                    <i data-lucide=\"mail\" class=\"w-4 h-4\"></i>\n                    Subscribe on Substack\n                </a>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n                <!-- Blog Item 1 -->\n                <article class=\"group cursor-pointer\">\n                    <div class=\"aspect-[16/9] bg-[#fffdf7]/5 rounded-xl mb-6 overflow-hidden border border-[#fffdf7]/10\">\n                         <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/c543a9e1-f226-4ced-80b0-feb8445a75b9_1600w.jpg\" alt=\"Books and tea\" class=\"w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity duration-500\">\n                    </div>\n                    <div class=\"flex items-center gap-4 mb-3 text-[#fffdf7]/60 text-sm font-['Bodoni_Moda']\">\n                        <span>Research</span>\n                        <span class=\"w-1 h-1 bg-[#fffdf7]/40 rounded-full\"></span>\n                        <span>Oct 2023</span>\n                    </div>\n                    <h3 class=\"font-['Playfair_Display'] text-2xl md:text-3xl mb-3 group-hover:underline decoration-[#fffdf7]/30 underline-offset-4\">The Golden Hour: Understanding the Physiology</h3>\n                    <p class=\"text-[#fffdf7]/70 text-lg font-light leading-relaxed\">\n                        A deep dive into the hormonal cascade immediately following birth and why uninterrupted skin-to-skin matters for both mother and baby.\n                    </p>\n                </article>\n\n                <!-- Blog Item 2 -->\n                <article class=\"group cursor-pointer\">\n                    <div class=\"aspect-[16/9] bg-[#fffdf7]/5 rounded-xl mb-6 overflow-hidden border border-[#fffdf7]/10\">\n                        <img src=\"https://images.unsplash.com/photo-1518609878373-06d740f60d8b?q=80&amp;w=2070&amp;auto=format&amp;fit=crop\" alt=\"Pilates mat\" class=\"w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity duration-500\">\n                    </div>\n                    <div class=\"flex items-center gap-4 mb-3 text-[#fffdf7]/60 text-sm font-['Bodoni_Moda']\">\n                        <span>Movement</span>\n                        <span class=\"w-1 h-1 bg-[#fffdf7]/40 rounded-full\"></span>\n                        <span>Sep 2023</span>\n                    </div>\n                    <h3 class=\"font-['Playfair_Display'] text-2xl md:text-3xl mb-3 group-hover:underline decoration-[#fffdf7]/30 underline-offset-4\">Pelvic Floor Awareness in the Third Trimester</h3>\n                    <p class=\"text-[#fffdf7]/70 text-lg font-light leading-relaxed\">\n                        Why relaxation is just as important as strengthening when preparing for labor. Simple exercises to connect with your body.\n                    </p>\n                </article>\n            </div>\n        </div>\n    </section>\n\n    <!-- Footer / Contact -->\n    <footer id=\"contact\" class=\"py-24 px-6 border-t border-[#45572d]/10\">\n        <div class=\"max-w-3xl mx-auto text-center\">\n            <div class=\"mb-12 flex justify-center text-[#45572d]\">\n                <i data-lucide=\"leaf\" class=\"w-10 h-10 stroke-[1]\"></i>\n            </div>\n            \n            <h2 class=\"font-['Playfair_Display'] text-[#45572d] text-4xl md:text-5xl tracking-tight mb-8\">Let's connect</h2>\n            <p class=\"text-xl font-light mb-10 max-w-xl mx-auto\">\n                Whether you are looking for midwifery care or want to join a Pilates class, I would love to hear from you.\n            </p>\n\n            <div class=\"flex flex-col md:flex-row items-center justify-center gap-6 mb-16\">\n                <a href=\"mailto:hello@nurturedbysophie.com\" class=\"flex items-center gap-3 px-8 py-4 bg-[#45572d] text-[#fffdf7] rounded-full text-lg hover:bg-[#717e5c] transition-colors\">\n                    <i data-lucide=\"mail\" class=\"w-5 h-5\"></i>\n           